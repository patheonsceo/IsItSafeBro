    {
      "id": "weak-default-credentials",
      "name": "login accepts a common default credential pair",
      "description": "Login endpoints sometimes still accept the seed credentials a tutorial or AI used during scaffolding (admin/admin, test/test, root/root, etc.). If a probe with one of those pairs returns a token or session, anyone who has read the same tutorial can sign in as admin.",
      "category": "auth",
      "severity": "critical",
      "endpoints_hint": [
        "/login",
        "/api/login",
        "/api/auth/login",
        "/api/auth/signin",
        "/signin",
        "/api/signin",
        "/auth",
        "/api/auth",
        "/api/sessions"
      ],
      "request": {
        "method": "POST",
        "headers": { "Content-Type": "application/json" },
        "body": "{\"username\":\"admin\",\"password\":\"admin\"}"
      },
      "variations": [
        { "body": "{\"username\":\"admin\",\"password\":\"password\"}" },
        { "body": "{\"username\":\"admin\",\"password\":\"123456\"}" },
        { "body": "{\"username\":\"admin\",\"password\":\"admin123\"}" },
        { "body": "{\"email\":\"admin@admin.com\",\"password\":\"admin\"}" },
        { "body": "{\"email\":\"admin@example.com\",\"password\":\"password\"}" },
        { "body": "{\"username\":\"test\",\"password\":\"test\"}" },
        { "body": "{\"username\":\"root\",\"password\":\"root\"}" },
        { "body": "{\"username\":\"user\",\"password\":\"user\"}" },
        { "body": "{\"username\":\"guest\",\"password\":\"guest\"}" }
      ],
      "success_signal": {
        "kind": "all_of",
        "conditions": [
          { "kind": "status_in", "values": [200, 201] },
          {
            "kind": "body_not_contains_any",
            "patterns": ["invalid", "incorrect", "wrong", "not found", "fail", "denied", "unauthorized"],
            "case_insensitive": true
          },
          {
            "kind": "any_of",
            "conditions": [
              {
                "kind": "body_contains_any",
                "patterns": ["token", "session", "jwt", "access_token", "accessToken", "bearer"],
                "case_insensitive": true
              },
              { "kind": "header_present", "name": "set-cookie" }
            ]
          }
        ]
      },
      "fix_hint": "Remove any seed/demo credentials from the database before deploy. If you must have a default admin for local development, gate it behind NODE_ENV !== 'production' and rotate the password on first launch. Also enforce a minimum password complexity at signup so users cannot reintroduce the same weakness."
    },
    {
      "id": "login-empty-credentials-accepted",
      "name": "login accepts empty or null credentials",
      "description": "Some auth handlers compare submitted credentials to stored ones without first checking they are non-empty. If the stored value is also empty (a seed row with no password set), or if a comparison library short-circuits on empty input, an attacker can sign in with no password.",
      "category": "auth",
      "severity": "critical",
      "endpoints_hint": [
        "/login",
        "/api/login",
        "/api/auth/login",
        "/api/auth/signin",
        "/signin"
      ],
      "request": {
        "method": "POST",
        "headers": { "Content-Type": "application/json" },
        "body": "{\"username\":\"admin\",\"password\":\"\"}"
      },
      "variations": [
        { "body": "{\"username\":\"admin\",\"password\":null}" },
        { "body": "{\"email\":\"admin@admin.com\",\"password\":\"\"}" },
        { "body": "{\"username\":\"\",\"password\":\"\"}" }
      ],
      "success_signal": {
        "kind": "all_of",
        "conditions": [
          { "kind": "status_in", "values": [200, 201] },
          {
            "kind": "body_not_contains_any",
            "patterns": ["required", "missing", "empty", "invalid", "wrong", "fail", "unauthorized"],
            "case_insensitive": true
          },
          {
            "kind": "any_of",
            "conditions": [
              {
                "kind": "body_contains_any",
                "patterns": ["token", "session", "jwt", "access_token", "accessToken"],
                "case_insensitive": true
              },
              { "kind": "header_present", "name": "set-cookie" }
            ]
          }
        ]
      },
      "fix_hint": "Validate inputs at the top of the login handler — reject requests where username/email or password is missing, empty, or null before any DB lookup. Treat the validation as the auth check's prerequisite, not a separate optional layer."
    },
    {
      "id": "cors-misconfig-credentials-with-wildcard-or-reflected-origin",
      "name": "CORS allows arbitrary origins with credentials",
      "description": "If an API endpoint responds with both Access-Control-Allow-Origin: * (or the request's Origin echoed back) and Access-Control-Allow-Credentials: true, a malicious website can make authenticated cross-origin requests on behalf of any victim who happens to be logged in. Wildcard-with-credentials is forbidden by the CORS spec but some servers misconfigure it; reflected-origin-with-credentials is a more common misconfiguration that achieves the same effect.",
      "category": "auth",
      "severity": "high",
      "endpoints_hint": [
        "/api",
        "/api/",
        "/api/me",
        "/api/user",
        "/api/users",
        "/api/auth",
        "/api/admin"
      ],
      "request": {
        "method": "OPTIONS",
        "headers": {
          "Origin": "https://isitsafebro-attacker.example",
          "Access-Control-Request-Method": "GET",
          "Access-Control-Request-Headers": "Authorization"
        }
      },
      "variations": [
        { "method": "GET", "headers": { "Origin": "https://isitsafebro-attacker.example" } }
      ],
