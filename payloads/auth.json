{
  "category": "auth",
  "version": 1,
  "payloads": [
    {
      "id": "unauthenticated-admin-route",
      "name": "unauthenticated admin route",
      "description": "Pages or APIs under /admin commonly require authentication on the page layer but forget the API or vice versa. If a probe with no credentials returns 200 with admin-like content and without a login prompt, anyone on the public internet can read or use it.",
      "category": "auth",
      "severity": "critical",
      "endpoints_hint": [
        "/admin",
        "/admin/",
        "/admin/dashboard",
        "/admin/users",
        "/admin/settings",
        "/api/admin",
        "/api/admin/users",
        "/api/admin/dashboard",
        "/dashboard/admin",
        "/internal/admin"
      ],
      "request": { "method": "GET" },
      "success_signal": {
        "kind": "all_of",
        "conditions": [
          { "kind": "status_in", "values": [200] },
          {
            "kind": "body_contains_any",
            "patterns": ["admin panel", "user list", "users", "settings", "manage", "dashboard"],
            "case_insensitive": true
          },
          {
            "kind": "body_not_contains_any",
            "patterns": ["sign in", "log in", "login required", "unauthorized", "forbidden", "please authenticate"],
            "case_insensitive": true
          }
        ]
      },
      "fix_hint": "Require an authenticated session on every /admin route. In Next.js, add a middleware.ts that checks for a valid session and redirects unauthenticated users to /login. In Express, mount an auth middleware on the /admin router. Repeat on the API counterpart (e.g., /api/admin/*).",
      "repro_hint": "curl -i '{base_url}{path}'"
    },
    {
      "id": "unauthenticated-write-endpoint",
      "name": "write-capable API endpoint accepts requests without auth",
      "description": "POST/PUT/DELETE/PATCH endpoints that change server state should reject requests without credentials. If a probe with an empty body and no auth header returns 200/201/204 (rather than 401/403), anyone can hit the endpoint. Body is intentionally empty — we are testing the auth check, not the validation path.",
      "category": "auth",
      "severity": "high",
      "endpoints_hint": [
        "/api/users",
        "/api/admin/users",
        "/api/posts",
        "/api/products",
        "/api/orders",
        "/api/comments",
        "/api/items",
        "/api/tasks",
        "/api/messages",
        "/api/projects"
      ],
      "request": {
        "method": "POST",
        "headers": { "Content-Type": "application/json" },
        "body": "{}"
      },
      "variations": [
        { "method": "PUT" },
        { "method": "PATCH" },
        { "method": "DELETE", "body": "" }
      ],
      "success_signal": {
        "kind": "all_of",
        "conditions": [
          { "kind": "status_in", "values": [200, 201, 202, 204] },
          {
            "kind": "body_not_contains_any",
            "patterns": ["unauthorized", "not authenticated", "log in", "sign in", "missing token", "forbidden", "csrf"],
            "case_insensitive": true
          }
        ]
      },
      "fix_hint": "Wrap every state-changing API route with an authentication check. Most frameworks have a middleware idiom: in Next.js use middleware.ts plus per-route session checks, in Express add a requireAuth middleware before the route handler. Returning a 400 for empty bodies is not a substitute — the auth check must come first."
    },
    {
      "id": "jwt-alg-none-bypass",
      "name": "JWT alg:none token accepted as valid",
      "description": "JWTs verified with a library that does not reject the alg:none algorithm can be forged trivially — an attacker just base64-encodes their desired claims and presents them as a Bearer token with no signature. If the server returns user data when given this token, JWT verification is broken.",
      "category": "auth",
      "severity": "critical",
      "endpoints_hint": [
        "/api/me",
        "/api/user",
        "/api/users/me",
        "/api/profile",
        "/api/auth/me",
        "/api/auth/session",
        "/api/session",
        "/api/account"
      ],
      "request": {
        "method": "GET",
        "headers": {
          "Authorization": "Bearer eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJzdWIiOiIxIiwiaWQiOjEsInVzZXJfaWQiOjEsInVzZXJJZCI6MSwiZW1haWwiOiJhZG1pbkBleGFtcGxlLmNvbSIsInJvbGUiOiJhZG1pbiIsImlzQWRtaW4iOnRydWUsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjo5OTk5OTk5OTk5fQ."
        }
      },
      "success_signal": {
        "kind": "all_of",
        "conditions": [
          { "kind": "status_in", "values": [200] },
          {
            "kind": "body_contains_any",
            "patterns": ["admin@example.com", "\"role\"", "\"email\"", "\"id\"", "\"sub\"", "\"user_id\"", "\"userId\""],
            "case_insensitive": false
          }
        ]
      },
      "fix_hint": "Use a JWT verification library that rejects alg:none and require it to whitelist the algorithm explicitly. For Node, use jsonwebtoken with jwt.verify(token, secret, { algorithms: ['HS256'] }) — do not omit the algorithms option. Same idea for jose / @auth/core: pin the algorithm.",
      "repro_hint": "curl -i -H 'Authorization: Bearer eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJzdWIiOiIxIiwiaWQiOjEsInVzZXJfaWQiOjEsInVzZXJJZCI6MSwiZW1haWwiOiJhZG1pbkBleGFtcGxlLmNvbSIsInJvbGUiOiJhZG1pbiIsImlzQWRtaW4iOnRydWUsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjo5OTk5OTk5OTk5fQ.' '{base_url}{path}'"
    },
    {
