{
  "name": "isitsafebro",
  "version": "0.0.1",
  "description": "is it safe, bro? red-team your vibe-coded app before you ship. a claude code plugin.",
  "keywords": [
    "security",
    "red-team",
    "claude-code",
    "claude-code-plugin",
    "mcp",
    "owasp",
    "vibe-coding",
    "ai-security",
    "prompt-injection"
  ],
  "homepage": "https://github.com/patheonsceo/IsItSafeBro",
  "bugs": {
    "url": "https://github.com/patheonsceo/IsItSafeBro/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patheonsceo/IsItSafeBro.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "isitsafebro": "dist/bin/isitsafebro.js"
  },
  "files": [
    "dist",
    ".claude-plugin",
    ".mcp.json",
    "commands",
    "agents",
    "skills",
    "payloads",
    "prompts",
    "scripts",
    "LICENSE",
    "README.md",
    "isitsafeproject.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/isitsafebro.ts",
    "start": "node dist/bin/isitsafebro.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && node scripts/test-snap.mjs && node scripts/test-worktree.mjs && node scripts/test-payloads.mjs && node scripts/test-attack.mjs && node scripts/test-fix-loop.mjs",
    "test:e2e:snap": "npm run build && node scripts/test-snap.mjs",
    "test:e2e:worktree": "npm run build && node scripts/test-worktree.mjs",
    "test:e2e:payloads": "npm run build && node scripts/test-payloads.mjs",
    "test:e2e:attack": "npm run build && node scripts/test-attack.mjs",
    "test:e2e:fix": "npm run build && node scripts/test-fix-loop.mjs",
    "demo": "npm run build && node scripts/demo.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "get-port": "^7.2.0",
    "simple-git": "^3.36.0",
    "undici": "^8.2.0",
    "zod": "^4.4.3"
  }
}
